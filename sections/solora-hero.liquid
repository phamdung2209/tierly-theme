{%- comment -%}
  Solora premium hero — self-contained, shopvid-inspired.
  Add via Theme editor → Add section → "Solora hero". Safe: touches nothing else.
{%- endcomment -%}

{%- style -%}
  #SoloraHero-{{ section.id }} {
    --sh-bg-from: {{ section.settings.bg_from }};
    --sh-bg-to: {{ section.settings.bg_to }};
    --sh-grad-from: {{ section.settings.grad_from }};
    --sh-grad-to: {{ section.settings.grad_to }};
    --sh-ink: {{ section.settings.text_color }};
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: clamp(6rem, 12vw, 11rem) 2rem clamp(5rem, 9vw, 8rem);
    background: radial-gradient(120% 120% at 50% 0%, var(--sh-bg-from) 0%, var(--sh-bg-to) 60%, var(--sh-bg-to) 100%);
    color: var(--sh-ink);
    text-align: center;
  }
  #SoloraHero-{{ section.id }} .sh__aurora { position: absolute; inset: -20% -10% auto -10%; height: 130%; z-index: -1; filter: blur(72px); opacity: .9; pointer-events: none; }
  #SoloraHero-{{ section.id }} .sh__blob { position: absolute; border-radius: 50%; will-change: transform; }
  #SoloraHero-{{ section.id }} .sh__blob--1 { width: 42vw; height: 42vw; left: -6vw; top: -8vw; background: {{ section.settings.blob_1 }}; animation: sh-float-1 15s ease-in-out infinite; }
  #SoloraHero-{{ section.id }} .sh__blob--2 { width: 38vw; height: 38vw; right: -8vw; top: -4vw; background: {{ section.settings.blob_2 }}; animation: sh-float-2 18s ease-in-out infinite; }
  #SoloraHero-{{ section.id }} .sh__blob--3 { width: 34vw; height: 34vw; left: 32vw; top: 6vw; background: {{ section.settings.blob_3 }}; opacity: .8; animation: sh-float-3 21s ease-in-out infinite; }

  #SoloraHero-{{ section.id }} .sh__inner { max-width: 82rem; margin: 0 auto; display: flex; flex-direction: column; align-items: center; }

  #SoloraHero-{{ section.id }} .sh__badge {
    display: inline-flex; align-items: center; gap: .6rem;
    font-family: "Inter", sans-serif; font-size: 1.3rem; font-weight: 600; letter-spacing: .02em;
    padding: .7rem 1.4rem; border-radius: 999px; margin-bottom: 2.4rem;
    background: rgba(255,255,255,.65); color: var(--sh-ink);
    border: 1px solid rgba(0,0,0,.06); backdrop-filter: blur(8px);
    box-shadow: 0 4px 20px rgba(0,0,0,.05);
  }
  #SoloraHero-{{ section.id }} .sh__badge::before { content: ""; width: .8rem; height: .8rem; border-radius: 50%; background: var(--sh-grad-from); box-shadow: 0 0 0 .4rem rgba(255,122,47,.18); }

  #SoloraHero-{{ section.id }} .sh__title {
    font-family: "Fraunces", Georgia, serif; font-weight: 600;
    font-size: clamp(3.6rem, 7vw, 7rem); line-height: 1.02; letter-spacing: -.02em; margin: 0;
  }
  #SoloraHero-{{ section.id }} .sh__accent {
    display: block; font-style: italic; font-weight: 500;
    background: linear-gradient(100deg, var(--sh-grad-from), var(--sh-grad-to));
    -webkit-background-clip: text; background-clip: text; color: transparent;
    padding-bottom: .08em;
  }
  #SoloraHero-{{ section.id }} .sh__sub {
    font-family: "Inter", sans-serif; font-size: clamp(1.6rem, 2vw, 2rem); line-height: 1.6;
    max-width: 56rem; margin: 2.4rem auto 0; opacity: .72; font-weight: 400;
  }
  #SoloraHero-{{ section.id }} .sh__cta { display: flex; flex-wrap: wrap; gap: 1.2rem; justify-content: center; margin-top: 3.6rem; }
  #SoloraHero-{{ section.id }} .sh__btn {
    font-family: "Inter", sans-serif; font-size: 1.6rem; font-weight: 600; text-decoration: none;
    padding: 1.5rem 3.2rem; border-radius: 999px; transition: transform .2s ease, box-shadow .2s ease, background .2s ease;
    display: inline-flex; align-items: center; gap: .8rem;
  }
  #SoloraHero-{{ section.id }} .sh__btn--primary {
    color: #fff; border: none;
    background: linear-gradient(100deg, var(--sh-grad-from), var(--sh-grad-to));
    box-shadow: 0 12px 30px -8px rgba(255,77,109,.5);
  }
  #SoloraHero-{{ section.id }} .sh__btn--primary:hover { transform: translateY(-2px); box-shadow: 0 18px 38px -8px rgba(255,77,109,.6); }
  #SoloraHero-{{ section.id }} .sh__btn--ghost {
    color: var(--sh-ink); background: rgba(255,255,255,.55); border: 1px solid rgba(0,0,0,.1);
  }
  #SoloraHero-{{ section.id }} .sh__btn--ghost:hover { transform: translateY(-2px); background: rgba(255,255,255,.9); }
  #SoloraHero-{{ section.id }} .sh__trust { font-family: "Inter", sans-serif; font-size: 1.35rem; opacity: .55; margin-top: 2.4rem; }

  @keyframes sh-float-1 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(3vw,2vw)} }
  @keyframes sh-float-2 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-3vw,3vw)} }
  @keyframes sh-float-3 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(2vw,-2vw)} }
  @media (prefers-reduced-motion: reduce) { #SoloraHero-{{ section.id }} .sh__blob { animation: none !important; } }
{%- endstyle -%}

<section id="SoloraHero-{{ section.id }}">
  <div class="sh__aurora" aria-hidden="true">
    <span class="sh__blob sh__blob--1"></span>
    <span class="sh__blob sh__blob--2"></span>
    <span class="sh__blob sh__blob--3"></span>
  </div>
  <div class="sh__inner">
    {%- if section.settings.badge != blank -%}
      <span class="sh__badge">{{ section.settings.badge }}</span>
    {%- endif -%}
    <h1 class="sh__title">
      {{ section.settings.heading }}
      {%- if section.settings.heading_accent != blank -%}
        <span class="sh__accent">{{ section.settings.heading_accent }}</span>
      {%- endif -%}
    </h1>
    {%- if section.settings.subheading != blank -%}
      <p class="sh__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
    {%- if section.settings.button_label_1 != blank or section.settings.button_label_2 != blank -%}
      <div class="sh__cta">
        {%- if section.settings.button_label_1 != blank -%}
          <a class="sh__btn sh__btn--primary" href="{{ section.settings.button_link_1 | default: '#' }}">{{ section.settings.button_label_1 }}</a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a class="sh__btn sh__btn--ghost" href="{{ section.settings.button_link_2 | default: '#' }}">{{ section.settings.button_label_2 }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}
    {%- if section.settings.trust != blank -%}
      <p class="sh__trust">{{ section.settings.trust }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Solora hero",
  "tag": "section",
  "class": "solora-hero-section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "badge", "label": "Eyebrow badge", "default": "New · Volume pricing that sells" },
    { "type": "text", "id": "heading", "label": "Heading (line 1)", "default": "Buy more," },
    { "type": "text", "id": "heading_accent", "label": "Accent line (gradient italic)", "default": "save more." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Automatic quantity breaks applied right at checkout — no codes, no theme edits. Watch your average order value climb." },
    { "type": "text", "id": "trust", "label": "Trust line", "default": "No code needed · Works on every theme · Live in minutes" },
    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "button_label_1", "label": "Primary button label", "default": "Shop the collection" },
    { "type": "url", "id": "button_link_1", "label": "Primary button link" },
    { "type": "text", "id": "button_label_2", "label": "Secondary button label", "default": "See how it works" },
    { "type": "url", "id": "button_link_2", "label": "Secondary button link" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_from", "label": "Background top", "default": "#FFF6EE" },
    { "type": "color", "id": "bg_to", "label": "Background bottom", "default": "#FFF0F3" },
    { "type": "color", "id": "grad_from", "label": "Accent gradient from", "default": "#FF7A2F" },
    { "type": "color", "id": "grad_to", "label": "Accent gradient to", "default": "#FF4D6D" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#1A1410" },
    { "type": "color", "id": "blob_1", "label": "Aurora blob 1", "default": "#FFC79A" },
    { "type": "color", "id": "blob_2", "label": "Aurora blob 2", "default": "#FF9DB8" },
    { "type": "color", "id": "blob_3", "label": "Aurora blob 3", "default": "#FFE0B0" }
  ],
  "presets": [{ "name": "Solora hero" }]
}
{% endschema %}
