{%- style -%}
  #SoloraPCta-{{ section.id }} { padding: 0; margin: clamp(4rem, 6vw, 6rem) 0 0; }
  #SoloraPCta-{{ section.id }} .pc__band {
    margin: 0 2.4rem; border-radius: 3.2rem; text-align: center;
    background: linear-gradient(150deg, #FFE9DA, #FFDCE6 60%, #FFD3E0);
    padding: clamp(4rem, 6vw, 5.6rem) clamp(2rem, 4vw, 4rem);
  }
  #SoloraPCta-{{ section.id }} .pc__eyebrow { font-family: var(--sol-sans); font-size: 1.2rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--sol-accent); }
  #SoloraPCta-{{ section.id }} h2 {
    font-family: var(--sol-sans); font-weight: 700; font-size: clamp(2.6rem, 4vw, 3.6rem);
    line-height: 1.12; letter-spacing: -0.03em; color: var(--sol-ink); margin: 1.4rem auto 0; max-width: 22ch;
  }
  #SoloraPCta-{{ section.id }} h2 em { font-family: var(--sol-serif); font-style: italic; font-weight: 500; color: var(--sol-pink); }
  #SoloraPCta-{{ section.id }} .pc__lead { font-family: var(--sol-sans); font-size: 1.6rem; line-height: 1.6; color: var(--sol-ink-soft); margin: 1.6rem auto 0; max-width: 52ch; }
  #SoloraPCta-{{ section.id }} .pc__tiers { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-top: 2.8rem; }
  #SoloraPCta-{{ section.id }} .pc__tier {
    background: rgba(255, 255, 255, 0.75); border: 1px solid rgba(255, 255, 255, 0.9);
    border-radius: 999px; padding: 0.9rem 1.8rem; font-family: var(--sol-sans);
    font-size: 1.35rem; font-weight: 600; color: var(--sol-ink); white-space: nowrap;
  }
  #SoloraPCta-{{ section.id }} .pc__tier em { font-style: normal; color: var(--sol-accent); }
  #SoloraPCta-{{ section.id }} .sol-btn { margin-top: 3rem; }
  #SoloraPCta-{{ section.id }} .pc__note { font-family: var(--sol-sans); font-size: 1.3rem; color: var(--sol-ink-faint); margin: 2rem 0 0; }
{%- endstyle -%}
<section id="SoloraPCta-{{ section.id }}">
  <div class="pc__band" data-sol-stagger>
    <span class="pc__eyebrow">{{ section.settings.eyebrow }}</span>
    <h2>{{ section.settings.heading }} <em>{{ section.settings.heading_accent }}</em></h2>
    <p class="pc__lead">{{ section.settings.subheading }}</p>
    {%- if section.settings.tiers != blank -%}
      <div class="pc__tiers">
        {%- assign rows = section.settings.tiers | split: ',' -%}
        {%- for row in rows -%}
          {%- assign parts = row | split: '=' -%}
          <span class="pc__tier">{{ parts[0] | strip }} <em>{{ parts[1] | strip }}</em></span>
        {%- endfor -%}
      </div>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a class="sol-btn sol-btn--primary" href="{{ section.settings.button_link | default: routes.root_url }}">{{ section.settings.button_label }}</a>
    {%- endif -%}
    {%- if section.settings.note != blank -%}
      <p class="pc__note">{{ section.settings.note }}</p>
    {%- endif -%}
  </div>
</section>
{% schema %}
{
  "name": "Solora product CTA",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Powered by Tierly" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "This store buys better" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (italic)", "default": "in bulk." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Tierly applies quantity breaks automatically at checkout — no discount codes for shoppers to hunt down, and nothing to edit in the theme." },
    { "type": "text", "id": "tiers", "label": "Example tiers (Label=Value, separated by commas)", "default": "Buy 3+=10% off, Buy 6+=18% off, Buy 12+=25% off" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Add Tierly free" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "text", "id": "note", "label": "Footnote", "default": "Example tiers — every threshold is set by the merchant." }
  ],
  "presets": [{ "name": "Solora product CTA" }]
}
{% endschema %}
