{%- comment -%} Solora FAQ — Tierly. Questions come from blocks. {%- endcomment -%}
{%- style -%}
  #SoloraFaq-{{ section.id }} { padding: clamp(6rem, 8vw, 8rem) 2rem; background: {{ section.settings.bg }}; }
  #SoloraFaq-{{ section.id }} .fq__head { text-align: center; margin-bottom: 4.4rem; }
  #SoloraFaq-{{ section.id }} .sol-title { margin-top: 1.4rem; }
  #SoloraFaq-{{ section.id }} .fq__list { max-width: 74rem; margin: 0 auto; }
  #SoloraFaq-{{ section.id }} details { border-bottom: 1px solid var(--sol-line); }
  #SoloraFaq-{{ section.id }} summary { list-style: none; cursor: pointer; padding: 2.2rem 0.4rem; display: flex; justify-content: space-between; align-items: center; gap: 2rem; font-family: var(--sol-sans); font-weight: 600; font-size: 1.65rem; color: var(--sol-ink); }
  #SoloraFaq-{{ section.id }} summary::-webkit-details-marker { display: none; }
  #SoloraFaq-{{ section.id }} .plus { width: 2.2rem; height: 2.2rem; flex: none; position: relative; }
  #SoloraFaq-{{ section.id }} .plus::before, #SoloraFaq-{{ section.id }} .plus::after { content: ""; position: absolute; background: var(--sol-accent); border-radius: 2px; inset: 50% 0 auto 0; height: 2px; transform: translateY(-50%); transition: transform 0.2s; }
  #SoloraFaq-{{ section.id }} .plus::after { transform: translateY(-50%) rotate(90deg); }
  #SoloraFaq-{{ section.id }} details[open] .plus::after { transform: translateY(-50%) rotate(0); }
  #SoloraFaq-{{ section.id }} details p { padding: 0 0.4rem 2.4rem; font-family: var(--sol-sans); font-size: 1.5rem; line-height: 1.6; color: var(--sol-ink-soft); max-width: 62rem; }
{%- endstyle -%}
<section id="SoloraFaq-{{ section.id }}">
  <span id="faq" class="sol-anchor" aria-hidden="true"></span>
  <div class="fq__head">
    <span class="sol-eyebrow">{{ section.settings.eyebrow }}</span>
    <h2 class="sol-title">{{ section.settings.heading }} <em>{{ section.settings.heading_accent }}</em></h2>
  </div>
  <div class="fq__list" data-sol-stagger>
    {%- for block in section.blocks -%}
      <details {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
        <summary>{{ block.settings.question }}<span class="plus"></span></summary>
        <p>{{ block.settings.answer }}</p>
      </details>
    {%- endfor -%}
  </div>
</section>
{% schema %}
{
  "name": "Solora FAQ",
  "tag": "section",
  "settings": [
    { "type": "color", "id": "bg", "label": "Background", "default": "#FFF4EC" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FAQ" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Questions" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (italic)", "default": "before you install." }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Will it slow down my store?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "No. Tierly applies discounts at the checkout layer, so there's no heavy script on your storefront. Your Core Web Vitals stay clean." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Solora FAQ",
      "blocks": [
        { "type": "item", "settings": { "question": "Will it slow down my store?", "answer": "No. Tierly applies discounts at the checkout layer, so there's no heavy script on your storefront. Your Core Web Vitals stay clean." } },
        { "type": "item", "settings": { "question": "Do I need a developer?", "answer": "No. Everything is set from Tierly's admin — pick quantities and discounts, choose what they apply to, and publish. Nothing to touch in your theme." } },
        { "type": "item", "settings": { "question": "Does it work with my theme?", "answer": "Yes. Because the discount runs at checkout, Tierly works on any Shopify theme, out of the box — including custom ones." } },
        { "type": "item", "settings": { "question": "What if I cancel?", "answer": "Your discounts simply stop applying. There's nothing left behind in your theme to clean up, since Tierly never edited it." } },
        { "type": "item", "settings": { "question": "Which discount types are supported?", "answer": "Quantity breaks, tiered percentages, bundle pricing, and cart-value goals — targeted at all products, specific products, or whole collections." } }
      ]
    }
  ]
}
{% endschema %}
