{%- comment -%} Solora feature showcase — "Discounts that just fit" {%- endcomment -%}
{%- style -%}
  #SoloraFeat-{{ section.id }} { padding: clamp(6rem, 8vw, 8rem) 2rem; background: linear-gradient(180deg, var(--sol-cream) 0%, var(--sol-cream-2) 100%); }
  #SoloraFeat-{{ section.id }} .ft__grid { max-width: 108rem; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.05fr; gap: 5rem; align-items: center; }
  #SoloraFeat-{{ section.id }} .ft__head .sol-title { margin-top: 1.4rem; font-size: clamp(2.6rem, 3.4vw, 3.6rem); }
  #SoloraFeat-{{ section.id }} .ft__head .sol-lead { margin-top: 1.6rem; }
  #SoloraFeat-{{ section.id }} .opts { margin: 2.8rem -2rem 0; display: flex; flex-direction: column; gap: 1rem; }
  #SoloraFeat-{{ section.id }} .opt { display: flex; gap: 1.4rem; align-items: flex-start; padding: 1.8rem 2rem; border-radius: 1.6rem; border: 1px solid transparent; transition: all 0.2s; }
  #SoloraFeat-{{ section.id }} .opt--on { background: #fff; border-color: var(--sol-line); box-shadow: 0 16px 34px -24px rgba(42, 27, 18, 0.35); }
  #SoloraFeat-{{ section.id }} .opt .dot { width: 0.8rem; height: 0.8rem; border-radius: 50%; background: var(--sol-ink-faint); margin-top: 0.77rem; flex: none; }
  #SoloraFeat-{{ section.id }} .opt--on .dot { background: var(--sol-accent); box-shadow: 0 0 0 0.4rem rgba(255, 94, 58, 0.15); }
  #SoloraFeat-{{ section.id }} .opt h4 { font-family: var(--sol-serif); font-weight: 500; font-size: 1.8rem; line-height: 1.3; color: var(--sol-ink); margin: 0; }
  #SoloraFeat-{{ section.id }} .opt p { font-family: var(--sol-sans); font-size: 1.35rem; color: var(--sol-ink-soft); margin: 0.4rem 0 0; }
  #SoloraFeat-{{ section.id }} .ft__prev { background: linear-gradient(160deg, #FFE9DA, #FFDFE6); border-radius: 2.6rem; padding: 4rem; box-shadow: 0 40px 80px -40px rgba(255, 77, 109, 0.4); }
  #SoloraFeat-{{ section.id }} .pc { background: #fff; border-radius: 1.8rem; padding: 2.4rem; box-shadow: 0 20px 40px -24px rgba(42, 27, 18, 0.3); }
  #SoloraFeat-{{ section.id }} .pc h5 { font-family: var(--sol-sans); font-size: 1.4rem; font-weight: 600; color: var(--sol-ink); }
  #SoloraFeat-{{ section.id }} .pc .sub { font-family: var(--sol-sans); font-size: 1.25rem; color: var(--sol-ink-faint); margin: 0.4rem 0 1.4rem; }
  #SoloraFeat-{{ section.id }} .pc__tiers { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; }
  #SoloraFeat-{{ section.id }} .pt { text-align: center; padding: 2rem 0.8rem; border: 1px solid var(--sol-line); border-radius: 1.4rem; }
  #SoloraFeat-{{ section.id }} .pt.on { border-color: transparent; background: var(--sol-grad); color: #fff; }
  #SoloraFeat-{{ section.id }} .pt .q { font-family: var(--sol-sans); font-size: 1.15rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; opacity: 0.7; }
  #SoloraFeat-{{ section.id }} .pt .o { font-family: var(--sol-serif); font-size: 3rem; margin: 0.6rem 0 0.2rem; }
  #SoloraFeat-{{ section.id }} .pt .n { font-family: var(--sol-sans); font-size: 1.1rem; opacity: 0.6; }
  @media (max-width: 989px) { #SoloraFeat-{{ section.id }} .ft__grid { grid-template-columns: 1fr; gap: 3rem; } }
{%- endstyle -%}
<section id="SoloraFeat-{{ section.id }}">
  <div class="ft__grid" data-sol-stagger>
    <div class="ft__head">
      <span class="sol-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="sol-title">{{ section.settings.heading }} <em>{{ section.settings.heading_accent }}</em></h2>
      <p class="sol-lead">{{ section.settings.subheading }}</p>
      <div class="opts" data-sol-stagger>
        <div class="opt opt--on"><span class="dot"></span><div><h4>Quantity breaks</h4><p>Buy 3, buy 6, buy 12 — a bigger discount at every threshold.</p></div></div>
        <div class="opt"><span class="dot"></span><div><h4>Tiered percentage</h4><p>The more they spend, the higher the % comes off.</p></div></div>
        <div class="opt"><span class="dot"></span><div><h4>Bundle price</h4><p>A fixed price when specific products are bought together.</p></div></div>
        <div class="opt"><span class="dot"></span><div><h4>Cart-value goal</h4><p>Unlock a reward once the cart crosses an amount.</p></div></div>
      </div>
    </div>
    <div class="ft__prev">
      <div class="pc">
        <h5>Volume pricing</h5>
        <p class="sub">Applied automatically at checkout</p>
        <div class="pc__tiers">
          <div class="pt"><div class="q">Buy 3+</div><div class="o">10%</div><div class="n">off</div></div>
          <div class="pt on"><div class="q">Buy 6+</div><div class="o">18%</div><div class="n">off</div></div>
          <div class="pt"><div class="q">Buy 12+</div><div class="o">25%</div><div class="n">off</div></div>
        </div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Solora feature",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Discount types" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Discounts that" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (italic)", "default": "just fit." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Every store prices differently. Pick the model that matches yours — Tierly applies it automatically as the cart grows." }
  ],
  "presets": [{ "name": "Solora feature" }]
}
{% endschema %}
