{%- comment -%} Solora reviews — Tierly. NOTE: placeholder testimonials — replace with real reviews before publishing. {%- endcomment -%}
{%- style -%}
  #SoloraRev-{{ section.id }} { padding: clamp(6rem, 8vw, 8rem) 2rem; text-align: center; background: {{ section.settings.bg }}; }
  #SoloraRev-{{ section.id }} .sol-title { margin-top: 1.4rem; }
  #SoloraRev-{{ section.id }} .stars { color: var(--sol-accent); font-size: 2rem; letter-spacing: 0.3rem; margin-top: 1.4rem; }
  #SoloraRev-{{ section.id }} .rv__grid { max-width: 108rem; margin: 4.4rem auto 0; columns: 3; column-gap: 2rem; text-align: left; }
  #SoloraRev-{{ section.id }} .rv { break-inside: avoid; background: #fff; border: 1px solid var(--sol-line); border-radius: 1.8rem; padding: 2.4rem; margin-bottom: 2rem; }
  #SoloraRev-{{ section.id }} .rv .s { color: var(--sol-accent); font-size: 1.3rem; letter-spacing: 0.2rem; }
  #SoloraRev-{{ section.id }} .rv p { font-family: var(--sol-sans); font-size: 1.45rem; line-height: 1.6; color: var(--sol-ink); margin: 1.2rem 0 1.6rem; }
  #SoloraRev-{{ section.id }} .rv .who { display: flex; align-items: center; gap: 1rem; }
  #SoloraRev-{{ section.id }} .rv .av { width: 3.4rem; height: 3.4rem; border-radius: 50%; background: var(--sol-grad); flex: none; }
  #SoloraRev-{{ section.id }} .rv .nm { font-family: var(--sol-sans); font-size: 1.35rem; font-weight: 600; color: var(--sol-ink); }
  #SoloraRev-{{ section.id }} .rv .rl { font-family: var(--sol-sans); font-size: 1.2rem; color: var(--sol-ink-faint); }
  @media (max-width: 989px) { #SoloraRev-{{ section.id }} .rv__grid { columns: 1; } }
{%- endstyle -%}
{%- liquid
  assign quotes = section.settings.quotes | newline_to_br | split: '<br />'
  assign names = section.settings.names | split: '|'
  assign roles = section.settings.roles | split: '|'
-%}
<section id="SoloraRev-{{ section.id }}">
  <span class="sol-eyebrow">{{ section.settings.eyebrow }}</span>
  <h2 class="sol-title">{{ section.settings.heading }} <em>{{ section.settings.heading_accent }}</em></h2>
  <div class="stars">★★★★★</div>
  <div class="rv__grid" data-sol-reveal>
    {%- for q in quotes -%}
      {%- assign qt = q | strip -%}
      {%- if qt != blank -%}
        <div class="rv">
          <div class="s">★★★★★</div>
          <p>{{ qt }}</p>
          <div class="who"><span class="av"></span><div><div class="nm">{{ names[forloop.index0] | strip }}</div><div class="rl">{{ roles[forloop.index0] | strip }}</div></div></div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>
{% schema %}
{
  "name": "Solora reviews",
  "tag": "section",
  "settings": [
    { "type": "paragraph", "content": "Placeholder testimonials — replace with real reviews before publishing." },
    { "type": "color", "id": "bg", "label": "Background", "default": "#FFFBF7" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Reviews" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Don't take our word" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (italic)", "default": "for it." },
    { "type": "textarea", "id": "quotes", "label": "Quotes (one per line)", "default": "Set up three tiers in ten minutes and our average order value jumped almost right away.\nNo code, no theme mess. It just worked and the discount shows up right at checkout.\nThe dashboard showing the AOV lift sold my boss instantly.\nSupport answered in minutes and helped me target a single collection.\nSwitched from a coupon-code setup and never looked back.\nClean admin, sensible defaults, and it didn't slow the store down at all." },
    { "type": "textarea", "id": "names", "label": "Names (separate with |)", "default": "Maya R.|Daniel K.|Priya S.|Tom W.|Lena F.|Omar B." },
    { "type": "textarea", "id": "roles", "label": "Roles (separate with |)", "default": "Home & living|Supplements brand|Apparel & accessories|Coffee roaster|Skincare shop|Streetwear label" }
  ],
  "presets": [{ "name": "Solora reviews" }]
}
{% endschema %}
