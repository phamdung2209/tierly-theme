{%- comment -%}
  Solora — "Where Tierly shows up": faithful, INTERACTIVE previews of the three
  storefront surfaces Tierly touches. Markup + behaviour mirror the real app blocks:
  extensions/theme-app-extension/blocks/{price-table,cart-upsell}.liquid
  (both price-table layouts: "table" and "cards") + the Function's checkout line.
  Clicking a tier sets the quantity; the quantity highlights the tier it reaches —
  exactly like the shipped block. Add a layout by adding a [data-layout] button and
  a matching [data-lay] panel; the tier JS is generic.
{%- endcomment -%}

{%- assign ac = section.settings.accent -%}
{%- style -%}
  #SoloraSurf-{{ section.id }} { background: {{ section.settings.bg }}; padding: clamp(6rem,9vw,9.5rem) 2rem; }
  #SoloraSurf-{{ section.id }} .sf__head { max-width: 66rem; margin: 0 auto 4rem; text-align: center; }
  #SoloraSurf-{{ section.id }} .sf__head .sol-lead { margin-top: 1.6rem; }

  #SoloraSurf-{{ section.id }} .sf__tabs { display: flex; gap: .6rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2.8rem; }
  #SoloraSurf-{{ section.id }} .sf__tab {
    font-family: var(--sol-sans); font-size: 1.45rem; font-weight: 600; cursor: pointer;
    padding: 1.1rem 2.2rem; border-radius: 999px; border: 1px solid var(--sol-line);
    background: #fff; color: var(--sol-ink-soft); transition: all .2s ease;
  }
  #SoloraSurf-{{ section.id }} .sf__tab:hover { color: var(--sol-ink); transform: translateY(-1px); }
  #SoloraSurf-{{ section.id }} .sf__tab.is-on { background: var(--sol-grad); color: #fff; border-color: transparent; box-shadow: 0 10px 24px -10px rgba(255,77,109,.55); }

  #SoloraSurf-{{ section.id }} .sf__stage { max-width: 82rem; margin: 0 auto; background: #fff; border: 1px solid var(--sol-line); border-radius: 2.2rem; overflow: hidden; box-shadow: 0 40px 80px -46px rgba(42,27,18,.45); }
  #SoloraSurf-{{ section.id }} .sf__chrome { display: flex; align-items: center; gap: 1.2rem; padding: 1.3rem 1.8rem; background: var(--sol-cream-2); border-bottom: 1px solid var(--sol-line-2); }
  #SoloraSurf-{{ section.id }} .sf__dots { display: flex; gap: .6rem; flex: none; }
  #SoloraSurf-{{ section.id }} .sf__dots i { width: 1rem; height: 1rem; border-radius: 50%; background: rgba(42,27,18,.14); }
  #SoloraSurf-{{ section.id }} .sf__url { flex: 1; text-align: center; font-family: var(--sol-sans); font-size: 1.2rem; color: var(--sol-ink-faint); background: #fff; border-radius: 999px; padding: .55rem 1.4rem; border: 1px solid var(--sol-line-2); }

  #SoloraSurf-{{ section.id }} .sf__panel { display: none; padding: clamp(2.4rem,4vw,4rem); }
  #SoloraSurf-{{ section.id }} .sf__panel.is-on { display: block; animation: sf-fade .35s ease both; }
  @keyframes sf-fade { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

  /* layout sub-toggle (Table / Cards / …) */
  #SoloraSurf-{{ section.id }} .sf__layouts { display: inline-flex; gap: .4rem; padding: .4rem; background: var(--sol-cream-2); border-radius: 999px; margin-bottom: 1.8rem; }
  #SoloraSurf-{{ section.id }} .sf__lbtn { font-family: var(--sol-sans); font-size: 1.25rem; font-weight: 600; cursor: pointer; border: none; background: transparent; color: var(--sol-ink-faint); padding: .7rem 1.6rem; border-radius: 999px; transition: all .18s ease; }
  #SoloraSurf-{{ section.id }} .sf__lbtn.is-on { background: #fff; color: var(--sol-ink); box-shadow: 0 2px 8px -2px rgba(42,27,18,.18); }
  #SoloraSurf-{{ section.id }} .lay { display: none; }
  #SoloraSurf-{{ section.id }} .lay.is-on { display: block; }

  /* shared widget chrome — mirrors the app block's own styling */
  #SoloraSurf-{{ section.id }} .w { font-family: var(--sol-sans); font-size: 1.4rem; line-height: 1.4; color: var(--sol-ink); }
  #SoloraSurf-{{ section.id }} .w__top { display: flex; justify-content: space-between; align-items: baseline; gap: 1.2rem; margin-bottom: .9rem; }
  #SoloraSurf-{{ section.id }} .w__title { font-weight: 600; }
  #SoloraSurf-{{ section.id }} .w__ends { font-size: 1.2rem; font-weight: 600; color: {{ ac }}; }
  #SoloraSurf-{{ section.id }} .w__box { border: 1px solid #e3e3e3; border-radius: 1.2rem; overflow: hidden; }
  #SoloraSurf-{{ section.id }} .w__row { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: .4rem 1.2rem; padding: 1.2rem 1.5rem; cursor: pointer; transition: box-shadow .18s ease; }
  #SoloraSurf-{{ section.id }} .w__row + .w__row { border-top: 1px solid #e3e3e3; }
  #SoloraSurf-{{ section.id }} .w__row--hl { background: color-mix(in srgb, {{ ac }} 7%, #fff); }
  #SoloraSurf-{{ section.id }} .w__buy { font-weight: 600; }
  #SoloraSurf-{{ section.id }} .w__badge { display: inline-block; margin-left: .5rem; font-size: 1.15rem; font-weight: 600; color: #fff; background: {{ ac }}; border-radius: .8rem; padding: .1rem .8rem; }
  #SoloraSurf-{{ section.id }} .w__right { text-align: right; white-space: nowrap; }
  #SoloraSurf-{{ section.id }} .w__each { font-weight: 700; color: {{ ac }}; }
  #SoloraSurf-{{ section.id }} .w__ea { color: #616161; }
  #SoloraSurf-{{ section.id }} .w__was { margin-left: .6rem; color: #8a8a8a; text-decoration: line-through; }
  #SoloraSurf-{{ section.id }} .w__save { display: block; font-size: 1.2rem; color: {{ ac }}; }

  /* cards layout (bundle picker) — mirrors the block's "cards" option */
  #SoloraSurf-{{ section.id }} .cds { display: grid; grid-template-columns: repeat(auto-fit, minmax(9.6rem, 1fr)); gap: .8rem; }
  #SoloraSurf-{{ section.id }} .cd { position: relative; border: 2px solid #e3e3e3; border-radius: 1.2rem; padding: 1.6rem .8rem 1.1rem; text-align: center; cursor: pointer; transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease; }
  #SoloraSurf-{{ section.id }} .cd__badge { position: absolute; top: -.9rem; left: 50%; transform: translateX(-50%); font-size: 1.1rem; font-weight: 600; color: #fff; background: {{ ac }}; border-radius: .8rem; padding: 0 .8rem; white-space: nowrap; }
  #SoloraSurf-{{ section.id }} .cd__qty { font-weight: 700; }
  #SoloraSurf-{{ section.id }} .cd__each { font-weight: 700; color: {{ ac }}; font-size: 1.6rem; }
  #SoloraSurf-{{ section.id }} .cd__ea { font-size: 1.1rem; color: #616161; }
  #SoloraSurf-{{ section.id }} .cd__was { font-size: 1.2rem; color: #8a8a8a; text-decoration: line-through; }
  #SoloraSurf-{{ section.id }} .cd__save { font-size: 1.1rem; color: {{ ac }}; }

  /* product context */
  #SoloraSurf-{{ section.id }} .pp { display: grid; grid-template-columns: 1fr 1.15fr; gap: 3rem; align-items: start; }
  #SoloraSurf-{{ section.id }} .pp__img { aspect-ratio: 1; border-radius: 1.6rem; background: linear-gradient(150deg, var(--sol-cream-2), #FFE6DC); display: grid; place-items: center; padding: 2rem; }
  #SoloraSurf-{{ section.id }} .pp__img img { width: 100%; height: 100%; object-fit: contain; }
  #SoloraSurf-{{ section.id }} .pp__name { font-family: var(--sol-sans); font-weight: 700; font-size: 2.2rem; letter-spacing: -.02em; margin: 0 0 .5rem; }
  #SoloraSurf-{{ section.id }} .pp__price { font-family: var(--sol-sans); font-size: 1.8rem; color: var(--sol-ink-soft); margin: 0 0 1.8rem; }
  #SoloraSurf-{{ section.id }} .pp__atc { margin-top: 1.8rem; display: flex; gap: 1rem; align-items: center; }
  #SoloraSurf-{{ section.id }} .qty { display: inline-flex; align-items: center; border: 1px solid var(--sol-line); border-radius: 999px; overflow: hidden; flex: none; }
  #SoloraSurf-{{ section.id }} .qty button { width: 3.8rem; height: 4.6rem; border: none; background: transparent; cursor: pointer; font-size: 1.9rem; line-height: 1; color: var(--sol-ink-soft); transition: background .15s ease; }
  #SoloraSurf-{{ section.id }} .qty button:hover { background: var(--sol-cream-2); color: var(--sol-ink); }
  #SoloraSurf-{{ section.id }} .qty output { min-width: 3.4rem; text-align: center; font-family: var(--sol-sans); font-weight: 600; font-size: 1.6rem; color: var(--sol-ink); }
  #SoloraSurf-{{ section.id }} .pp__cta { flex: 1; border-radius: 999px; padding: 1.3rem; text-align: center; font-family: var(--sol-sans); font-weight: 600; font-size: 1.5rem; color: #fff; background: var(--sol-ink); }
  #SoloraSurf-{{ section.id }} .pp__hint { font-family: var(--sol-sans); font-size: 1.25rem; color: var(--sol-ink-faint); margin: 1.2rem 0 0; }

  /* checkout */
  #SoloraSurf-{{ section.id }} .co { max-width: 46rem; margin: 0 auto; font-family: var(--sol-sans); }
  #SoloraSurf-{{ section.id }} .co__row { display: flex; justify-content: space-between; padding: 1.2rem 0; font-size: 1.5rem; color: var(--sol-ink-soft); }
  #SoloraSurf-{{ section.id }} .co__row--disc { color: {{ ac }}; font-weight: 600; }
  #SoloraSurf-{{ section.id }} .co__row--total { border-top: 1px solid var(--sol-line); margin-top: .6rem; padding-top: 1.8rem; font-size: 2rem; font-weight: 700; color: var(--sol-ink); }
  #SoloraSurf-{{ section.id }} .co__tag { display: inline-flex; align-items: center; gap: .6rem; font-size: 1.25rem; font-weight: 600; color: {{ ac }}; background: color-mix(in srgb, {{ ac }} 10%, #fff); border-radius: 999px; padding: .6rem 1.2rem; margin-bottom: 2rem; }

  #SoloraSurf-{{ section.id }} .sf__cta { text-align: center; margin-top: 3rem; }
  #SoloraSurf-{{ section.id }} .sf__cta svg { margin-left: .2rem; }
  #SoloraSurf-{{ section.id }} .sf__note { text-align: center; font-family: var(--sol-sans); font-size: 1.35rem; color: var(--sol-ink-faint); margin: 1.8rem auto 0; max-width: 62rem; }

  @media (max-width: 989px) {
    #SoloraSurf-{{ section.id }} .pp { grid-template-columns: 1fr; gap: 2.4rem; }
    #SoloraSurf-{{ section.id }} .pp__img { max-width: 34rem; margin: 0 auto; }
  }

  @media (max-width: 749px) {
    #SoloraSurf-{{ section.id }} { padding: 5rem 1.2rem; }
    #SoloraSurf-{{ section.id }} .sf__head { margin-bottom: 2.8rem; }
    #SoloraSurf-{{ section.id }} .sf__url { display: none; }
    #SoloraSurf-{{ section.id }} .sf__chrome { padding: 1rem 1.4rem; }
    #SoloraSurf-{{ section.id }} .sf__stage { border-radius: 1.6rem; }
    #SoloraSurf-{{ section.id }} .sf__panel { padding: 1.8rem 1.4rem; }
    #SoloraSurf-{{ section.id }} .pp__img { display: none; }

    /* tabs: horizontal scroll instead of cramped wrapping */
    #SoloraSurf-{{ section.id }} .sf__tabs { flex-wrap: nowrap; overflow-x: auto; justify-content: flex-start; padding-bottom: .4rem; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
    #SoloraSurf-{{ section.id }} .sf__tabs::-webkit-scrollbar { display: none; }
    #SoloraSurf-{{ section.id }} .sf__tab { flex: none; padding: .9rem 1.6rem; font-size: 1.35rem; }

    /* price-table rows stack so prices never squeeze */
    #SoloraSurf-{{ section.id }} .w__row { flex-direction: column; align-items: flex-start; gap: .4rem; padding: 1.1rem 1.2rem; }
    #SoloraSurf-{{ section.id }} .w__right { text-align: left; white-space: normal; }
    #SoloraSurf-{{ section.id }} .w__was { margin-left: .4rem; }

    /* cards: two up, tighter */
    #SoloraSurf-{{ section.id }} .cds { grid-template-columns: repeat(2, 1fr); gap: 1.2rem .8rem; }
    #SoloraSurf-{{ section.id }} .cd { padding: 1.6rem .6rem 1rem; }

    #SoloraSurf-{{ section.id }} .pp__atc { flex-wrap: wrap; }
    #SoloraSurf-{{ section.id }} .pp__cta { flex: 1 1 100%; }
    #SoloraSurf-{{ section.id }} .co__row { font-size: 1.4rem; }
    #SoloraSurf-{{ section.id }} .co__row--total { font-size: 1.8rem; }
  }

  @media (max-width: 479px) {
    #SoloraSurf-{{ section.id }} .cds { grid-template-columns: 1fr; }
  }
{%- endstyle -%}

<section id="SoloraSurf-{{ section.id }}">
  <div class="sf__head" data-sol-reveal>
    <p class="sol-eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="sol-title">{{ section.settings.heading }}</h2>
    <p class="sol-lead">{{ section.settings.lead }}</p>
  </div>

  <div class="sf__tabs" role="tablist">
    <button class="sf__tab is-on" type="button" data-tab="product" data-url="/products/alpine-roast">Product page</button>
    <button class="sf__tab" type="button" data-tab="cart" data-url="/cart">Cart</button>
    <button class="sf__tab" type="button" data-tab="checkout" data-url="/checkout">Checkout</button>
  </div>

  <div class="sf__stage" data-sol-reveal>
    <div class="sf__chrome">
      <span class="sf__dots"><i></i><i></i><i></i></span>
      <span class="sf__url" data-url-out>your-store.myshopify.com/products/alpine-roast</span>
    </div>

    {%- comment -%} 1 — product page: the Tierly price table, both layouts {%- endcomment -%}
    <div class="sf__panel is-on" data-panel="product">
      <div class="pp">
        <div class="pp__img">
          <img src="{{ 'solora-flow-lockup.png' | asset_url }}" alt="Alpine Roast" width="800" height="800" loading="lazy">
        </div>
        <div>
          <h3 class="pp__name">Alpine Roast — 250g</h3>
          <p class="pp__price">$25.00</p>

          <div class="sf__layouts" role="tablist" aria-label="Price table layout">
            <button class="sf__lbtn is-on" type="button" data-layout="table">Table</button>
            <button class="sf__lbtn" type="button" data-layout="cards">Cards</button>
          </div>

          <div class="w">
            <div class="w__top">
              <span class="w__title">Buy more, save more</span>
              <span class="w__ends">Ends in 2d 5h</span>
            </div>

            {%- comment -%} layout: table {%- endcomment -%}
            <div class="lay is-on" data-lay="table">
              <div class="w__box">
                <div class="w__row" data-tier data-qty="3">
                  <span class="w__buy">Buy 3+</span>
                  <span class="w__right"><span class="w__each">$22.50</span><span class="w__ea">/ea</span><span class="w__was">$25.00</span><span class="w__save">Save $2.50/item</span></span>
                </div>
                <div class="w__row w__row--hl" data-tier data-qty="6" data-best>
                  <span class="w__buy">Buy 6+<span class="w__badge">Best value</span></span>
                  <span class="w__right"><span class="w__each">$20.50</span><span class="w__ea">/ea</span><span class="w__was">$25.00</span><span class="w__save">Save $4.50/item</span></span>
                </div>
                <div class="w__row" data-tier data-qty="12">
                  <span class="w__buy">Buy 12+</span>
                  <span class="w__right"><span class="w__each">$18.75</span><span class="w__ea">/ea</span><span class="w__was">$25.00</span><span class="w__save">Save $6.25/item</span></span>
                </div>
              </div>
            </div>

            {%- comment -%} layout: cards (bundle picker) {%- endcomment -%}
            <div class="lay" data-lay="cards">
              <div class="cds">
                <div class="cd" data-tier data-qty="3">
                  <div class="cd__qty">3+</div>
                  <div class="cd__each">$22.50</div>
                  <div class="cd__ea">/ea</div>
                  <div class="cd__was">$25.00</div>
                  <div class="cd__save">Save $2.50/item</div>
                </div>
                <div class="cd" data-tier data-qty="6" data-best>
                  <span class="cd__badge">Best value</span>
                  <div class="cd__qty">6+</div>
                  <div class="cd__each">$20.50</div>
                  <div class="cd__ea">/ea</div>
                  <div class="cd__was">$25.00</div>
                  <div class="cd__save">Save $4.50/item</div>
                </div>
                <div class="cd" data-tier data-qty="12">
                  <div class="cd__qty">12+</div>
                  <div class="cd__each">$18.75</div>
                  <div class="cd__ea">/ea</div>
                  <div class="cd__was">$25.00</div>
                  <div class="cd__save">Save $6.25/item</div>
                </div>
              </div>
            </div>
          </div>

          <div class="pp__atc">
            <span class="qty">
              <button type="button" data-step="-1" aria-label="Decrease quantity">−</button>
              <output data-qty-out>6</output>
              <button type="button" data-step="1" aria-label="Increase quantity">+</button>
            </span>
            <span class="pp__cta">Add to cart</span>
          </div>
          <p class="pp__hint">{{ section.settings.hint }}</p>
        </div>
      </div>
    </div>

    {%- comment -%} 2 — cart: the Tierly upsell nudges {%- endcomment -%}
    <div class="sf__panel" data-panel="cart">
      <div class="w" style="max-width:56rem;margin:0 auto">
        <div class="w__box">
          <div class="w__row" style="background:color-mix(in srgb, {{ ac }} 10%, #fff);font-weight:600;cursor:default">
            <span>Total savings</span>
            <span style="color:{{ ac }}">−$18.00</span>
          </div>
          <div class="w__row w__row--hl" style="font-weight:600;cursor:default"><span>Unlock bigger savings</span></div>
          <div class="w__row" style="cursor:default">
            <span>Alpine Roast — 250g</span>
            <span style="font-weight:600;color:{{ ac }}">Add 3 more to save 18%</span>
          </div>
          <div class="w__row" style="cursor:default">
            <span>Ceramic Dripper</span>
            <span style="font-weight:600;color:{{ ac }}">Add 1 more to save 10%</span>
          </div>
        </div>
      </div>
    </div>

    {%- comment -%} 3 — checkout: the Function's automatic discount line {%- endcomment -%}
    <div class="sf__panel" data-panel="checkout">
      <div class="co">
        <span class="co__tag">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          No discount code entered
        </span>
        <div class="co__row"><span>Subtotal · 6 items</span><span>$150.00</span></div>
        <div class="co__row co__row--disc"><span>Tierly volume pricing</span><span>−$27.00</span></div>
        <div class="co__row"><span>Shipping</span><span>Free</span></div>
        <div class="co__row co__row--total"><span>Total</span><span>$123.00</span></div>
      </div>
    </div>
  </div>

  {%- if section.settings.cta_label != blank -%}
    <div class="sf__cta" data-sol-reveal>
      <a class="sol-btn sol-btn--primary" href="{{ section.settings.cta_link | default: routes.all_products_collection_url }}">
        {{ section.settings.cta_label }}
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  {%- endif -%}

  <p class="sf__note">{{ section.settings.note }}</p>
</section>

<script>
  (function () {
    var root = document.getElementById('SoloraSurf-{{ section.id }}');
    if (!root) return;
    var accent = {{ ac | json }};

    /* ---- surface tabs ---- */
    var tabs = root.querySelectorAll('.sf__tab');
    var panels = root.querySelectorAll('.sf__panel');
    var urlOut = root.querySelector('[data-url-out]');
    var host = 'your-store.myshopify.com';
    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        tabs.forEach(function (t) { t.classList.toggle('is-on', t === tab); });
        panels.forEach(function (p) { p.classList.toggle('is-on', p.dataset.panel === tab.dataset.tab); });
        if (urlOut) urlOut.textContent = host + tab.dataset.url;
      });
    });

    /* ---- price-table layout toggle (extensible: add a button + matching [data-lay]) ---- */
    var lbtns = root.querySelectorAll('.sf__lbtn');
    var lays = root.querySelectorAll('.lay');
    lbtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        lbtns.forEach(function (b) { b.classList.toggle('is-on', b === btn); });
        lays.forEach(function (l) { l.classList.toggle('is-on', l.dataset.lay === btn.dataset.layout); });
        highlight();
      });
    });

    /* ---- quantity ↔ tier highlighting (mirrors the shipped block) ---- */
    var qty = 6;
    var out = root.querySelector('[data-qty-out]');
    var tiers = Array.prototype.slice.call(root.querySelectorAll('[data-tier]'));

    function highlight() {
      // group by layout so each layout highlights its own highest reached tier
      var groups = {};
      tiers.forEach(function (el) {
        var key = el.closest('[data-lay]') ? el.closest('[data-lay]').dataset.lay : 'x';
        (groups[key] = groups[key] || []).push(el);
      });
      Object.keys(groups).forEach(function (key) {
        var rows = groups[key];
        var active = null;
        rows.forEach(function (row) { if (qty >= parseInt(row.dataset.qty, 10)) active = row; });
        rows.forEach(function (row, i) {
          var on = row === active;
          if (row.classList.contains('cd')) {
            row.style.borderColor = on || row.hasAttribute('data-best') ? accent : '#e3e3e3';
            row.style.boxShadow = on ? '0 8px 18px -6px rgba(20,23,40,.22)' : 'none';
            row.style.transform = on ? 'translateY(-2px)' : '';
            return;
          }
          var r = '11px';
          row.style.boxShadow = on ? 'inset 0 0 0 2px ' + accent : 'none';
          row.style.borderRadius = !on ? ''
            : i === 0 ? r + ' ' + r + ' 0 0'
            : i === rows.length - 1 ? '0 0 ' + r + ' ' + r
            : '0';
        });
      });
    }

    function setQty(n) {
      qty = Math.max(1, n);
      if (out) out.textContent = qty;
      highlight();
    }

    root.querySelectorAll('.qty button').forEach(function (b) {
      b.addEventListener('click', function () { setQty(qty + parseInt(b.dataset.step, 10)); });
    });
    tiers.forEach(function (row) {
      row.addEventListener('click', function () { setQty(parseInt(row.dataset.qty, 10)); });
    });

    highlight();
  })();
</script>

{% schema %}
{
  "name": "Solora surfaces",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "See it in action" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your shoppers see it in three places." },
